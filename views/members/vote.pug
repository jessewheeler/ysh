extends layout

block page_title
    | #{vote.title}

block content
    a.btn-outline(href="/members" style="margin-bottom:1.5rem; display:inline-block") &larr; Back

    .admin-panel(style="margin-bottom:1.5rem")
        h2(style="margin-bottom:0.75rem")= vote.title
        if vote.description
            p(style="color:#555; margin-bottom:1rem")= vote.description
        if vote.closes_at
            p.text-muted(style="margin-bottom:1rem; font-size:0.875rem")
                | #{vote.status === 'closed' ? 'Closed' : 'Closes'} #{formatDateLong(vote.closes_at)}

        if myResponse
            .flash.flash-success(style="margin-bottom:1.5rem") Your vote: #{myResponse.label}
        else if vote.status === 'closed'
            .flash.flash-error(style="margin-bottom:1.5rem") This vote is closed.
        else
            form(method="POST" action=`/members/votes/${vote.id}`)
                input(type="hidden" name="_csrf" value=csrfToken)
                .form-group(style="margin-bottom:1rem")
                    each option in options
                        label(style="display:flex; align-items:center; gap:0.75rem; padding:0.625rem 0.75rem; border:1px solid #ccc; border-radius:6px; margin-bottom:0.5rem; cursor:pointer; background:#fff")
                            input(type="radio" name="option_id" value=option.id required)
                            span= option.label
                .form-actions
                    button.btn(type="submit") Submit Vote

    if results
        .admin-panel
            h3(style="margin-bottom:0.25rem") Results
            p.text-muted(style="margin-bottom:1.25rem; font-size:0.875rem") #{totalVotes} vote#{totalVotes !== 1 ? 's' : ''} cast
            each result in results
                - const pct = totalVotes > 0 ? Math.round(result.count / totalVotes * 100) : 0
                div(style="margin-bottom:1rem")
                    div(style="display:flex; justify-content:space-between; margin-bottom:0.375rem; font-size:0.9rem")
                        span= result.label
                        span(style="color:#666") #{result.count} (#{pct}%)
                    div(style="background:#e5e5e5; border-radius:4px; height:10px")
                        div(style=`background:#69be28; border-radius:4px; height:10px; width:${pct}%`)
