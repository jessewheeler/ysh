extends layout

block page_title
  | Site Settings

block content
  form(method="POST" action="/admin/settings" enctype="multipart/form-data")
    h3 Hero Section
    .form-group
      label(for="hero_title") Hero Title
      input#hero_title(type="text" name="hero_title" value=(site.hero_title || ''))
    .form-group
      label(for="hero_subtitle") Hero Subtitle
      textarea#hero_subtitle(name="hero_subtitle" rows="2")= site.hero_subtitle || ''
    .form-group
      label(for="hero_button_text") Hero Button Text
      input#hero_button_text(type="text" name="hero_button_text" value=(site.hero_button_text || ''))
    .form-group
      label(for="hero_button_url") Hero Button URL
      input#hero_button_url(type="text" name="hero_button_url" value=(site.hero_button_url || ''))

    .form-group
      label(for="hero_media_type") Hero Media Type
      select#hero_media_type(name="hero_media_type")
        option(value="none" selected=(site.hero_media_type === 'none' || !site.hero_media_type)) None (text only)
        option(value="photo" selected=(site.hero_media_type === 'photo')) Photo
        option(value="video" selected=(site.hero_media_type === 'video')) Video

    .form-group
      label(for="hero_media") Upload Hero Photo/Video
      input#hero_media(type="file" name="image" accept="image/*,video/*")
      if site.hero_media_url
        p.text-muted
          | Current:
          a(href=site.hero_media_url target="_blank") View current media
        input(type="hidden" name="hero_media_url" value=site.hero_media_url)
      p.text-muted
        | Accepted: Images (jpg, png, gif, webp) up to 50MB, Videos (mp4, webm, mov) up to 50MB
        br
        | Media will display at its natural size without stretching

    h3 About Section
    .form-group
      label(for="about_quote") About Quote
      textarea#about_quote(name="about_quote" rows="2")= site.about_quote || ''
    .form-group
      label(for="about_text") About Intro Text
      textarea#about_text(name="about_text" rows="3")= site.about_text || ''
    h4 About Pillars
    .form-group
      label(for="about_pillar1_title") Pillar 1 — Title
      input#about_pillar1_title(type="text" name="about_pillar1_title" value=(site.about_pillar1_title || ''))
    .form-group
      label(for="about_pillar1_text") Pillar 1 — Text
      textarea#about_pillar1_text(name="about_pillar1_text" rows="3")= site.about_pillar1_text || ''
    .form-group
      label(for="about_pillar2_title") Pillar 2 — Title
      input#about_pillar2_title(type="text" name="about_pillar2_title" value=(site.about_pillar2_title || ''))
    .form-group
      label(for="about_pillar2_text") Pillar 2 — Text
      textarea#about_pillar2_text(name="about_pillar2_text" rows="3")= site.about_pillar2_text || ''
    .form-group
      label(for="about_pillar3_title") Pillar 3 — Title
      input#about_pillar3_title(type="text" name="about_pillar3_title" value=(site.about_pillar3_title || ''))
    .form-group
      label(for="about_pillar3_text") Pillar 3 — Text
      textarea#about_pillar3_text(name="about_pillar3_text" rows="3")= site.about_pillar3_text || ''

    h3 Gallery
    .form-group
      label(for="gallery_album_url") Full Album URL
      input#gallery_album_url(type="text" name="gallery_album_url" value=(site.gallery_album_url || ''))

    h3 Membership
    .form-group
      label(for="dues_amount_cents") Annual Dues (cents, e.g. 2500 = $25.00)
      input#dues_amount_cents(type="number" name="dues_amount_cents" value=(site.dues_amount_cents || '2500'))

    h3 Contact
    .form-group
      label(for="contact_email") Contact Email (receives contact form submissions)
      input#contact_email(type="email" name="contact_email" value=(site.contact_email || ''))

    h3 Stripe
    .form-group
      label(for="stripe_publishable_key") Stripe Publishable Key (for frontend)
      input#stripe_publishable_key(type="text" name="stripe_publishable_key" value=(site.stripe_publishable_key || ''))

    h3 Renewal Reminders
    .form-group
      label(for="membership_expiry_date") Membership Expiry Date
      input#membership_expiry_date(type="date" name="membership_expiry_date" value=(site.membership_expiry_date || ''))
      p.text-muted The date when memberships expire. Used to set expiry on activation and to target renewal reminder emails.
    .form-group
      label(for="renewal_reminder_days_before") Send Reminders (days before expiry)
      input#renewal_reminder_days_before(type="number" name="renewal_reminder_days_before" value=(site.renewal_reminder_days_before || '30') min="1" max="365")
      p.text-muted Members with expiry dates within this many days will be included in renewal reminder sends.

    h3 Social Media
    .form-group
      label(for="social_facebook_url") Facebook Page URL
      input#social_facebook_url(type="url" name="social_facebook_url" value=(site.social_facebook_url || ''))
      p.text-muted Leave blank to hide
    .form-group
      label(for="social_instagram_url") Instagram URL
      input#social_instagram_url(type="url" name="social_instagram_url" value=(site.social_instagram_url || ''))
      p.text-muted Leave blank to hide

    .form-actions
      button.btn(type="submit") Save Settings
