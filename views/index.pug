extends layout

block content
  section#home-slider.hero
    //- Hero media (photo or video)
    if site.hero_media_type === 'photo' && site.hero_media_url
      .hero-media
        img.hero-image(src=site.hero_media_url alt="Hero image")
    else if site.hero_media_type === 'video' && site.hero_media_url
      .hero-media
        video.hero-video(autoplay muted loop playsinline)
          source(src=site.hero_media_url type="video/mp4")
          | Your browser does not support the video tag.

    //- Hero content overlay
    .hero-content
      h1= site.hero_title || 'Yellowstone Sea Hawkers'
      p= site.hero_subtitle || ''
      if site.hero_button_url
        a.btn(href=site.hero_button_url target="_blank")= site.hero_button_text || 'Learn More'

  section#news.section
    .container
      h2 Announcements
      .cards
        each ann in announcements
          .card
            if ann.image_path
              img(src=ann.image_path alt=ann.title)
            .card-body
              h3= ann.title
              p= ann.body
              if ann.link_url
                a.btn-outline(href=ann.link_url target="_blank")= ann.link_text || 'Learn More'

  section#about.section.alt-bg
    .container
      h2 About YSH
      if site.about_quote
        blockquote= site.about_quote
      if site.about_text
        p= site.about_text
        if site.about_pillar1_title || site.about_pillar2_title || site.about_pillar3_title
          .cards.cards-three
            if site.about_pillar1_title
              .card
                .card-body
                  h3= site.about_pillar1_title
                  if site.about_pillar1_text
                    p= site.about_pillar1_text
            if site.about_pillar2_title
              .card
                .card-body
                  h3= site.about_pillar2_title
                  if site.about_pillar2_text
                    p= site.about_pillar2_text
            if site.about_pillar3_title
              .card
                .card-body
                  h3= site.about_pillar3_title
                  if site.about_pillar3_text
                    p= site.about_pillar3_text

  section#gallery.section
    .container
      h2 Event Gallery
      .gallery-grid
        each img in gallery
          img(src=img.filename alt=img.alt_text || 'Gallery photo')
      if site.gallery_album_url
        p.text-center
          a.btn(href=site.gallery_album_url target="_blank") View Full Album

  section#membership.section.alt-bg
    .container
      h2 Membership
      .cards.cards-three
        .card
          .card-body
            h3 Join the Yellowstone Sea Hawkers
            p Become an official member and get your membership card!
            a.btn(href="/membership") Sign Up & Pay Dues

  section#charitable.section
    .container
      h2 Charitable Work
      .cards.cards-three
        .card
          .card-body
            h3 Battle of the Birds
            p Our annual fundraiser benefiting Billings Family Service.
            a.btn-outline(href="/charitable/battle-of-the-birds") Learn More
        .card
          .card-body
            h3 Annual Non-Profit Support
            p Over $10,000 raised for local charities.
            a.btn-outline(href="/charitable/nonprofits") Learn More
        .card
          .card-body
            h3 Heartwheels
            p Bringing joy to kids undergoing cancer treatment.
            a.btn-outline(href="/charitable/heartwheels") Learn More

  section#contact.section.alt-bg
    .container
      h2 Contact Us
      form.contact-form(method="POST" action="/contact")
        input(type="hidden" name="_csrf" value=(typeof csrfToken !== 'undefined' ? csrfToken : ''))
        .form-group
          label(for="name") Name
          input#name(type="text" name="name" placeholder="Your name" required)
        .form-group
          label(for="email") Email
          input#email(type="email" name="email" placeholder="Your email" required)
        .form-group
          label(for="message") Message
          textarea#message(name="message" rows="5" placeholder="Your message" required)
        if hcaptchaSiteKey
          .form-group
            .h-captcha(data-sitekey=hcaptchaSiteKey)
        button.btn(type="submit") Send Message
